---
import type { ServiceData, RepoServiceSection, SupportedSoftwareGridSection } from '@/types'
import { baseUrl } from '@/lib/baseUrl'

interface Props {
  data: ServiceData
}

const { data } = Astro.props
const base = baseUrl()
---

{data.sections.map(section => {
  if (section.type === 'repoService') {
    const s = section as RepoServiceSection
    return (
      <div class="tab-block">
        <h3>{s.repoAddress.label}</h3>
        <div class="code-row">
          <code>{s.repoAddress.url}</code>
          <button class="copy-btn" type="button" data-copy-text={s.repoAddress.url} aria-label="复制">
            <img class="copy-icon" src={`${base}icons/copy.svg`} alt="" width="16" height="16" />
          </button>
        </div>
        <h3>{s.usageExample.title}</h3>
        <div class="code-row">
         <code>{s.usageExample.code}</code>
          <button class="copy-btn" type="button" data-copy-text={s.usageExample.code} aria-label="复制">
            <img class="copy-icon" src={`${base}icons/copy.svg`} alt="" width="16" height="16" />
          </button>
        </div>
      </div>
    )
  }

  if (section.type === 'supportedSoftwareGrid') {
    const s = section as SupportedSoftwareGridSection
    return (
      <div class="tab-block">
        <h3>{s.title}</h3>
        <div class="software-table-wrap">
          <table class="software-table">
            <thead>
              <tr>
                <th scope="col">{s.columns.package}</th>
                <th scope="col">{s.columns.version}</th>
                <th scope="col">{s.columns.abi}</th>
              </tr>
            </thead>
            <tbody>
              {s.items.map(item => (
                <tr>
                  <td class="cell-name"><code>{item.name}</code></td>
                  <td class="cell-version"><code>{item.version}</code></td>
                  <td class="cell-abi">
                    {item.abi.map(tag => (
                      <span class="abi-tag">{tag}</span>
                    ))}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )
  }
})}

<style>
  .tab-block {
    margin-bottom: 24px;
  }

  h3 {
    margin: 18px 0 10px;
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .code-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .code-row code {
    background: #f3f4f6;
    padding: 10px 12px;
    border-radius: 10px;
    flex: 1;
    min-width: 0;
    word-break: break-all;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace;
    font-size: 13px;
    color: var(--text);
  }

  .code-block {
    background: #f3f4f6;
    color: var(--text);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace;
    padding: 16px;
    border-radius: 10px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    margin-top: 10px;
  }

  .code-block pre {
    margin: 0;
  }

  .copy-btn {
    border: 1px solid var(--border);
    background: var(--bg);
    border-radius: 10px;
    padding: 8px 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: #f9fafb;
  }

  .software-table-wrap {
    margin-top: 12px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--card);
  }

  .software-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .software-table th,
  .software-table td {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .software-table thead th {
    background: #f3f4f6;
    font-weight: 700;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }

  .software-table tbody tr:last-child td {
    border-bottom: none;
  }

  .software-table .cell-name code,
  .software-table .cell-version code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace;
    font-size: 13px;
    color: var(--text);
    background: transparent;
    padding: 0;
  }

  .software-table .cell-version {
    white-space: nowrap;
    width: 1%;
  }

  .cell-abi {
    line-height: 1.6;
  }

  .abi-tag {
    display: inline-block;
    margin: 2px 6px 2px 0;
    padding: 2px 8px;
    border-radius: 6px;
    background: #eef2ff;
    color: #3730a3;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace;
    font-size: 12px;
  }
</style>
