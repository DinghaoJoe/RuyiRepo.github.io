---
import Layout from '@/layouts/Layout.astro'
import IntroSection from '@/components/home/IntroSection.astro'
import ServiceSection from '@/components/home/ServiceSection/index.astro'
import FeedbackSection from '@/components/home/FeedbackSection.astro'
import zh from '@/i18n/zh'
import en from '@/i18n/en'
import { pypiZh, pypiEn } from '@/components/home/ServiceSection/data'
import type { SiteConfig } from '@/types'

interface Props {
  lang: 'zh' | 'en'
  /** 仅用于 `/` 中文首页：根据浏览器语言尝试跳转英文站 */
  enableRootLocaleRedirect?: boolean
}

const { lang, enableRootLocaleRedirect = false } = Astro.props
const config: SiteConfig = lang === 'en' ? en : zh
const serviceData = lang === 'en' ? { pypi: pypiEn } : { pypi: pypiZh }
---

<Layout lang={config.lang} enableRootLocaleRedirect={enableRootLocaleRedirect}>
  <IntroSection title={config.intro.title} paragraphs={config.intro.paragraphs} />
  <ServiceSection
    title={config.servicesTitle}
    lang={config.lang}
    serviceData={serviceData}
  />
  <FeedbackSection feedback={config.feedback} lang={config.lang} />
</Layout>
